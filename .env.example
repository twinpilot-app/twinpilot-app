# ══════════════════════════════════════════════════════════════════════════════
# Tirsa Factory — Command Center environment variables
#
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# For production (Vercel): set these in the Vercel dashboard under
# Settings → Environment Variables.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL and keys.
# Found at: https://supabase.com/dashboard/project/<id>/settings/api
#
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL ───────────────────────────────────────────────────────────────────
# Public URL where the Command Center is hosted.
# Used in notification links and OAuth redirects.
#
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com

# ── Admin bootstrap (LEGACY / optional) ─────────────────────────────────────
# First-admin promotion is now handled by the bootstrap trigger in the
# Supabase bundle (infra/supabase/bootstrap/admin-invite.sql.tmpl) — when
# the first invite is redeemed, auth.users.raw_app_meta_data.role is set
# to 'admin' automatically.
#
# ADMIN_PROMOTE_SECRET stays as an OPTIONAL manual-recovery escape hatch:
# if the trigger didn't fire (e.g. trigger was dropped, DB restored from a
# backup taken before bootstrap, etc.), you can set this secret and call
# POST /api/admin/promote to promote by email. Leave unset in normal deploys.
#
# ADMIN_PROMOTE_SECRET=

# ── Trigger.dev (optional fallback) ──────────────────────────────────────────
# Users configure their own Trigger.dev credentials via the /platforms UI.
# This variable is only needed as a fallback during development or if you
# want to provide a shared project for users who have not yet configured one.
#
# TRIGGER_SECRET_KEY=tr_prod_xxxxxxxxxxxxxxxxxxxx

# ── Brand (white-label) ──────────────────────────────────────────────────────
# Selects the active brand at build-time. Must match a file in
# branding/configs/<id>.json and a directory in branding/packs/<id>/.
# Runs via scripts/brand-prebuild.mjs on `npm install`, dev, and build.
# Default is "twinpilot" (the official product). Set to "tirsa" to build the
# legacy Tirsa brand.
#
BRAND_ID=twinpilot
